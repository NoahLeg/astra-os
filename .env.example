NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ASTRA_DB_PATH=./data/astra-os.sqlite

# Production database — server only, never prefix the secret with NEXT_PUBLIC_
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPER_ADMIN_EMAILS=
SECRETS_ENCRYPTION_KEY=

# Agent providers — server only
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
CRON_SECRET=
N8N_WEBHOOK_URL=
N8N_WEBHOOK_BEARER_TOKEN=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# OAuth Google Workspace (server only)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional locally; defaults to {site origin}/api/connections/google/callback
GOOGLE_REDIRECT_URI=

# Stripe Billing (server only). Create recurring monthly prices in Stripe.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
